{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "C#: Debug SimpleEF",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/bin/Debug/net8.0/SimpleEF.dll",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "serverReadyAction": {
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "{0}",
        "action": "openExternally"
      },
      "env": {
        "DOTNET_ROLL_FORWARD": "Major"
      },
      "console": "integratedTerminal"
    }
  ]
}
